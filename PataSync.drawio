  <diagram name="Página-1" id="_hcpFrw8xPZxX_aBsarl">
    <mxGraphModel dx="1459" dy="857" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\n    class Pessoa {\n        &lt;&lt;abstract&gt;&gt;\n        +String nome\n        +String cpf\n        +String telefone\n        +String endereco\n        +String profissao\n        +getNome() String\n        +getProfissao() String\n    }\n\n    class Funcionario {\n        &lt;&lt;abstract&gt;&gt;\n        +double salario\n        +registrarAtendimento(Animal animal, Atendimento atendimento)* void\n    }\n\n    class Veterinario {\n        +registrarAtendimento(Animal animal, Atendimento atendimento) void\n        +registrarDiagnostico(Atendimento atendimento, String descricao) void\n    }\n\n    class AssistenteVeterinario {\n        +registrarAtendimento(Animal animal, Atendimento atendimento) void\n        +aplicarMedicacao(Atendimento atendimento, Medicacao medicacao) void\n    }\n\n    class Atendente {\n        +registrarAtendimento(Animal animal, Atendimento atendimento) void\n    }\n\n    class Tutor {\n        +List~Animal~ animais\n    }\n\n    class Animal {\n        +String nome\n        +String especie\n        +String raca\n        +int idade\n        +double peso\n        +Tutor tutor\n        +List~Atendimento~ historicoAtendimentos\n    }\n\n    class Atendimento {\n        +Animal animal\n        +LocalDateTime dataHoraInicio\n        +LocalDateTime dataHoraFim\n        +Veterinario responsavelPrincipal\n        +List~Procedimento~ procedimentos\n        +List~Medicacao~ medicacoes\n        +List~AcaoAtendimento~ historicoAcoes\n        +calcularDuracao() long\n        +calcularTotal() double\n    }\n\n    class Procedimento {\n        +String descricao\n        +TipoProcedimento tipo\n        +double valorBase\n    }\n\n    class Medicacao {\n        +String nome\n        +String dosagem\n        +int quantidade\n        +double valorUnitario\n        +double valorTotal\n    }\n\n    class AcaoAtendimento {\n        +Funcionario responsavel\n        +TipoAcaoAtendimento tipo\n        +String descricao\n        +LocalDateTime dataHora\n        +Procedimento procedimento\n        +Medicacao medicacao\n    }\n\n    class TipoAcaoAtendimento {\n        &lt;&lt;enumeration&gt;&gt;\n        ABERTURA\n        PRIMEIRO_ATENDIMENTO\n        MEDICACAO\n        DIAGNOSTICO\n        PROCEDIMENTO\n        ENCERRAMENTO\n    }\n\n    class TipoProcedimento {\n        &lt;&lt;enumeration&gt;&gt;\n        EXAME\n        CIRURGIA\n        CONSULTA\n        INTERNACAO\n    }\n\n    Pessoa &lt;|-- Funcionario\n    Pessoa &lt;|-- Tutor\n    Funcionario &lt;|-- Veterinario\n    Funcionario &lt;|-- AssistenteVeterinario\n    Funcionario &lt;|-- Atendente\n    Tutor \&quot;1\&quot; --&gt; \&quot;*\&quot; Animal\n    Animal \&quot;1\&quot; --&gt; \&quot;*\&quot; Atendimento\n    Atendimento \&quot;1\&quot; --&gt; \&quot;*\&quot; AcaoAtendimento\n    Atendimento \&quot;1\&quot; --&gt; \&quot;*\&quot; Procedimento\n    Atendimento \&quot;1\&quot; --&gt; \&quot;*\&quot; Medicacao\n    Funcionario \&quot;1\&quot; --&gt; \&quot;*\&quot; AcaoAtendimento&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="Y99qGoxh765ByzuW-0IS-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
