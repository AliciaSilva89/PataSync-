CREATE TABLE assistente_veterinario (
    assistente_id   SERIAL PRIMARY KEY,
    funcionario_id  INTEGER NOT NULL,
    CONSTRAINT fk_assistente_funcionario
        FOREIGN KEY (funcionario_id) REFERENCES funcionario(funcionario_id)
);

SELECT funcionario_id, p.nome, tipo_funcionario
FROM funcionario f
JOIN pessoa p ON p.pessoa_id = f.pessoa_id
ORDER BY funcionario_id;

